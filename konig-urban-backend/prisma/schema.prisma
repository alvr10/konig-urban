// ============================================================
// KÖNIG URBAN — PostgreSQL Schema (Supabase)
//
// Setup:
//   1. Paste the trigger SQL at the bottom into Supabase SQL editor
//   2. Set DATABASE_URL (pooler port 6543)
// ============================================================


generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  schemas   = ["catalog", "production", "hr", "marketing", "finance", "customers", "orders"]
}

// ─── CATALOG SCHEMA ─────────────────────────────────────────────────────────

model Categoria {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String   @unique @db.VarChar(100)
  descripcion String?
  prendas     Prenda[]

  @@map("categorias")
  @@schema("catalog")
}

model Coleccion {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre            String    @db.VarChar(150)
  temporada         String?   @db.VarChar(50)
  descripcion       String?
  fechaLanzamiento  DateTime? @db.Date @map("fecha_lanzamiento")
  estado            String    @db.VarChar(20) // 'borrador','publicada','agotada'
  createdAt         DateTime  @default(now()) @db.Timestamptz @map("created_at")
  prendas           Prenda[]
  drop              Drop?

  @@map("colecciones")
  @@schema("catalog")
}

model Prenda {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coleccionId     String   @db.Uuid @map("coleccion_id")
  categoriaId     String   @db.Uuid @map("categoria_id")
  nombre          String   @db.VarChar(150)
  descripcion     String?
  precio          Decimal  @db.Decimal(10, 2)
  gramajeAlgodon  Int?     @map("gramaje_algodon")
  material        String?  @db.VarChar(200)
  imagenUrl       String?  @db.Text @map("imagen_url")
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz @map("created_at")

  coleccion       Coleccion @relation(fields: [coleccionId], references: [id])
  categoria       Categoria @relation(fields: [categoriaId], references: [id])
  uids            IdentificadorUnico[]

  @@map("prendas")
  @@schema("catalog")
}

model Drop {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coleccionId  String    @unique @db.Uuid @map("coleccion_id")
  fechaInicio  DateTime  @db.Timestamptz @map("fecha_inicio")
  fechaFin     DateTime  @db.Timestamptz @map("fecha_fin")
  activo       Boolean   @default(false)
  descripcion  String?
  createdAt    DateTime  @default(now()) @db.Timestamptz @map("created_at")
  
  coleccion    Coleccion @relation(fields: [coleccionId], references: [id])

  @@map("drops")
  @@schema("catalog")
}

model IdentificadorUnico {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prendaId        String   @db.Uuid @map("prenda_id")
  uidCodigo       String   @unique @db.VarChar(64) @map("uid_codigo")
  numeroSerie     Int      @map("numero_serie")
  totalSerie      Int      @map("total_serie")
  estado          String   @default("disponible") @db.VarChar(20) // 'disponible','reservado','vendido'
  fechaGeneracion DateTime @default(now()) @db.Timestamptz @map("fecha_generacion")

  prenda          Prenda   @relation(fields: [prendaId], references: [id])

  @@map("identificadores_unicos")
  @@schema("catalog")
}

// ─── PRODUCTION SCHEMA ──────────────────────────────────────────────────────

model Proveedor {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String         @db.VarChar(200)
  tipo       String         @db.VarChar(30) // 'tejidos','fabricacion','packaging'
  contacto   String?        @db.VarChar(150)
  email      String?        @db.VarChar(255)
  pais       String?        @db.VarChar(100)
  activo     Boolean        @default(true)
  createdAt  DateTime       @default(now()) @db.Timestamptz @map("created_at")
  ordenes    OrdenCompra[]

  @@map("proveedores")
  @@schema("production")
}

model OrdenCompra {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  proveedorId  String         @db.Uuid @map("proveedor_id")
  fecha        DateTime       @db.Date
  estado       String         @default("borrador") @db.VarChar(20) // 'borrador','confirmada','recibida','cancelada'
  total        Decimal?       @db.Decimal(12, 2)
  notas        String?
  createdAt    DateTime       @default(now()) @db.Timestamptz @map("created_at")
  
  proveedor    Proveedor      @relation(fields: [proveedorId], references: [id])
  lineas       LineaOrdenCompra[]

  @@map("ordenes_compra")
  @@schema("production")
}

model LineaOrdenCompra {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenId            String      @db.Uuid @map("orden_id")
  descripcionMaterial String      @db.VarChar(300) @map("descripcion_material")
  cantidad           Int
  precioUnitario     Decimal     @db.Decimal(10, 2) @map("precio_unitario")

  orden              OrdenCompra @relation(fields: [ordenId], references: [id])

  @@map("lineas_orden_compra")
  @@schema("production")
}

model ControlCalidad {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prendaId      String   @db.Uuid @map("prenda_id") // FK lógica a catalog.prendas
  inspector     String   @db.VarChar(150)
  fechaRevision DateTime @default(now()) @db.Timestamptz @map("fecha_revision")
  resultado     String   @db.VarChar(20) // 'aprobado','rechazado'
  notas         String?
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("control_calidad")
  @@schema("production")
}

// ─── HR SCHEMA ──────────────────────────────────────────────────────────────

model Departamento {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre    String     @unique @db.VarChar(100)
  empleados Empleado[]

  @@map("departamentos")
  @@schema("hr")
}

model Empleado {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departamentoId  String         @db.Uuid @map("departamento_id")
  nombre          String         @db.VarChar(100)
  apellidos       String         @db.VarChar(150)
  email           String         @unique @db.VarChar(255)
  cargo           String?        @db.VarChar(100)
  fechaContratacion DateTime     @db.Date @map("fecha_contratacion")
  salario         Decimal        @db.Decimal(10, 2)
  activo          Boolean        @default(true)
  createdAt       DateTime       @default(now()) @db.Timestamptz @map("created_at")

  departamento    Departamento   @relation(fields: [departamentoId], references: [id])
  contratos       Contrato[]
  nominas         Nomina[]

  @@map("empleados")
  @@schema("hr")
}

model Contrato {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empleadoId    String   @db.Uuid @map("empleado_id")
  tipoContrato  String   @db.VarChar(50) @map("tipo_contrato") // 'indefinido','temporal','practicas'
  fechaInicio   DateTime @db.Date @map("fecha_inicio")
  fechaFin      DateTime? @db.Date @map("fecha_fin")
  salarioBruto  Decimal  @db.Decimal(10, 2) @map("salario_bruto")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  empleado      Empleado @relation(fields: [empleadoId], references: [id])

  @@map("contratos")
  @@schema("hr")
}

model Nomina {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empleadoId    String   @db.Uuid @map("empleado_id")
  periodo       String   @db.VarChar(7) // YYYY-MM
  salarioBruto  Decimal  @db.Decimal(10, 2) @map("salario_bruto")
  deducciones   Decimal  @default(0) @db.Decimal(10, 2)
  salarioNeto   Decimal  @db.Decimal(10, 2) @map("salario_neto") // Note: generated column in SQL
  fechaPago     DateTime? @db.Date @map("fecha_pago")
  pagada        Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  empleado      Empleado @relation(fields: [empleadoId], references: [id])

  @@unique([empleadoId, periodo], name: "uq_nomina_empleado_periodo")
  @@map("nominas")
  @@schema("hr")
}

// ─── MARKETING SCHEMA ───────────────────────────────────────────────────────

model Campana {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre       String             @db.VarChar(200)
  tipo         String             @db.VarChar(30) // 'newsletter','influencer','redes','drop'
  coleccionId  String?            @db.Uuid @map("coleccion_id") // FK lógica
  fechaInicio  DateTime           @db.Date @map("fecha_inicio")
  fechaFin     DateTime?          @db.Date @map("fecha_fin")
  estado       String             @default("planificada") @db.VarChar(20) // 'planificada','activa','finalizada','cancelada'
  descripcion  String?
  createdAt    DateTime           @default(now()) @db.Timestamptz @map("created_at")
  clientes     ClienteCampana[]

  @@map("campanas")
  @@schema("marketing")
}

model ClienteCampana {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campanaId  String   @db.Uuid @map("campana_id")
  clienteId  String   @db.Uuid @map("cliente_id") // FK lógica a customers.clientes
  enviado    Boolean  @default(false)
  fechaEnvio DateTime? @db.Timestamptz @map("fecha_envio")

  campana    Campana  @relation(fields: [campanaId], references: [id])

  @@unique([campanaId, clienteId], name: "uq_cliente_campana")
  @@map("clientes_campana")
  @@schema("marketing")
}

// ─── FINANCE SCHEMA ─────────────────────────────────────────────────────────

model Factura {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId      String   @unique @db.Uuid @map("pedido_id") // FK lógica a orders.pedidos
  clienteId     String   @db.Uuid @map("cliente_id") // FK lógica a customers.clientes
  numeroFactura String   @unique @db.VarChar(50) @map("numero_factura")
  fechaEmision  DateTime @default(now()) @db.Timestamptz @map("fecha_emision")
  total         Decimal  @db.Decimal(10, 2)
  estado        String   @default("emitida") @db.VarChar(20) // 'emitida','pagada','anulada'
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("facturas")
  @@schema("finance")
}

model MargenProducto {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  prendaId         String   @db.Uuid @map("prenda_id") // FK lógica a catalog.prendas
  costeProduccion  Decimal  @db.Decimal(10, 2) @map("coste_produccion")
  precioVenta      Decimal  @db.Decimal(10, 2) @map("precio_venta")
  margenPorcentaje Decimal  @db.Decimal(5, 2) @map("margen_porcentaje") // Note: generated column in SQL
  fechaCalculo     DateTime @default(now()) @db.Date @map("fecha_calculo")

  @@map("margenes_producto")
  @@schema("finance")
}

// ─── CUSTOMERS SCHEMA ────────────────────────────────────────────────────────

model Cliente {
  id            String      @id @db.Uuid @map("id")
  nombre        String      @db.VarChar(100)
  apellidos     String      @db.VarChar(150)
  email         String      @unique @db.VarChar(255)
  telefono      String?     @db.VarChar(20)
  direccion     String?     @db.Text
  tipoCliente   String      @default("estandar") @db.VarChar(20) @map("tipo_cliente")
  fechaRegistro DateTime    @default(now()) @db.Timestamptz @map("fecha_registro")
  activo        Boolean     @default(true)
  membresia     Membresia?

  @@map("clientes")
  @@schema("customers")
}

model Membresia {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId         String   @unique @db.Uuid @map("cliente_id")
  nivel             String   @db.VarChar(20)
  fechaInicio       DateTime @db.Date @map("fecha_inicio")
  accesoAnticipado  Boolean  @default(false) @map("acceso_anticipado")
  activa            Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz @map("created_at")
  
  cliente           Cliente  @relation(fields: [clienteId], references: [id])

  @@map("membresias")
  @@schema("customers")
}

model Pedido {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId       String         @db.Uuid @map("cliente_id") // Logical FK to customers.clientes
  fecha           DateTime       @default(now()) @db.Timestamptz
  estado          String         @default("pendiente") @db.VarChar(20)
  total           Decimal        @db.Decimal(10, 2)
  metodoPago      String?        @db.VarChar(50) @map("metodo_pago")
  stripeSessionId String?        @unique @db.VarChar(255) @map("stripe_session_id")
  createdAt       DateTime       @default(now()) @db.Timestamptz @map("created_at")
  
  lineas          LineaPedido[]
  envio           Envio?

  @@map("pedidos")
  @@schema("orders")
}

model LineaPedido {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId       String   @db.Uuid @map("pedido_id")
  prendaId       String   @db.Uuid @map("prenda_id")     // Logical FK to catalog.prendas
  uidPrendaId    String?  @db.Uuid @map("uid_prenda_id") // Logical FK to catalog.identificadores_unicos
  cantidad       Int      @default(1)
  precioUnitario Decimal  @db.Decimal(10, 2) @map("precio_unitario")
  
  pedido         Pedido   @relation(fields: [pedidoId], references: [id])

  @@map("lineas_pedido")
  @@schema("orders")
}

model Envio {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId              String    @unique @db.Uuid @map("pedido_id")
  operadorLogistico     String?   @db.VarChar(100) @map("operador_logistico")
  trackingUrl           String?   @db.Text @map("tracking_url")
  estadoEnvio           String    @default("pendiente") @db.VarChar(30) @map("estado_envio")
  fechaEnvio            DateTime? @db.Timestamptz @map("fecha_envio")
  fechaEntregaEstimada  DateTime? @db.Date @map("fecha_entrega_estimada")
  packagingPremium      Boolean   @default(true) @map("packaging_premium")
  createdAt             DateTime  @default(now()) @db.Timestamptz @map("created_at")
  
  pedido                Pedido    @relation(fields: [pedidoId], references: [id])

  @@map("envios")
  @@schema("orders")
}
